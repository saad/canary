# Canary — sponsor integrations. Everything is optional; missing values
# degrade to local fallbacks. Copy to .env and fill in as keys arrive.

# AWS Bedrock (classification agent, Step 2) — uses default boto3 credential chain
AWS_REGION=us-west-2
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-6

# ClickHouse sink (Step 5)
CLICKHOUSE_ENABLED=false
CLICKHOUSE_URL=
CLICKHOUSE_USER=
CLICKHOUSE_PASSWORD=

# Langfuse tracing (Step 5)
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=

# Thesys / OpenUI dashboard (Step 6)
THESYS_API_KEY=

# Google Maps geocoding (Step 3; falls back to Nominatim)
GOOGLE_MAPS_API_KEY=

# Guildai agent governance (Step 2 gate wrapper; SDK details from booth)
GUILDAI_ENABLED=false
GUILDAI_API_KEY=

# Demo pacing (seconds between source polls; default 10)
DEMO_POLL_SECONDS=10

# Tripwire: force the locally-composed workspace instead of Thesys C1
C1_DISABLED=false

# Real notification delivery via email (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
NOTIFY_EMAIL_TO=
